action test(n int) {
    if false {
        check 1 else test_fail("check 1")
    }

    if false {
        check 1 else test_fail("check 2")
    } else {
        check 2 else test_fail("check 3")
    }

    if false {
        check 1 else test_fail("check 4")
        let c = add(1, 1)
    } else if n == 2 {
        check 3 else test_fail("check 5")
    } else if n == 4 {
        check 5 else test_fail("check 6")
    } else {
        check 6 else test_fail("check 7")
    }
}
