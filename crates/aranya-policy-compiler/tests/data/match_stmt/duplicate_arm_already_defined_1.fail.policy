command Result {
    fields {
        x int
    }
    seal { return todo() }
    open { return todo() }
    policy {
        finish {}
    }
}

action foo(x int) {
    match x {
        5 => {
            publish Result { x: x }
        }
        6 => {
            publish Result { x: x }
        }
        5 => {
            publish Result { x: x }
        }
    }
}
