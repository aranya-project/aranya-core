command Result {
    fields {
        x int
    }
    seal { return todo() }
    open { return todo() }
    policy { }
}

action foo(x int) {
    match x {
        5 => {
            publish Result { x: x }
        }
        _ => {
            publish Result { x: 0 }
        }
        6 => {
            publish Result { x: x }
        }
    }
}
