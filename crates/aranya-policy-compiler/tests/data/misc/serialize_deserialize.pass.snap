---
Module {
    version: "0",
    labels: {
        <policy 'Foo'>: 1,
        <recall 'Foo'>: 8,
        <seal 'Foo'>: 11,
        <open 'Foo'>: 20,
    },
    action_defs: {},
    command_defs: {
        CommandDef {
            name: "Foo" @ 46..49,
            persistence: Persistent,
            attributes: {},
